{
	"name": "scratch-project-guides",
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "npm run generate-projects && vite dev",
		"build": "npm run generate-projects && vite build",
		"prepare": "svelte-kit sync",
		"preview": "npm run generate-projects && vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"test:e2e": "playwright test",
		"test": "npm run test:e2e",
		"licenses": "npx generate-license-file --input package.json --output third-party-licenses.txt --overwrite",
		"generate-projects": "node scripts/generate-projects.js && npm run format",
		"generate-workflows": "node scripts/generate-workflows.js && npm run format"
	},
	"devDependencies": {
		"@playwright/test": "^1.59.1",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.58.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/postcss": "^4.2.4",
		"autoprefixer": "^10.5.0",
		"baseline-browser-mapping": "^2.9.19",
		"eslint": "^10.2.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.1",
		"generate-license-file": "^4.1.1",
		"globals": "^17.5.0",
		"markdown-it": "^14.1.1",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"scratchblocks": "^3.6.4",
		"svelte": "^5.43.8",
		"svelte-check": "^4.4.6",
		"tailwindcss": "^4.0.6",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.59.1",
		"vite": "^8.0.10"
	},
	"dependencies": {
		"tesseract.js": "^7.0.0"
	}
}
